#!/bin/bash

caffeine=$($HOME/.local/bin/caffeine-mode)
scrot='󰄄'
calendar=''
notification=$($HOME/.local/bin/dunst-notifications-toggle)

chosen=$(echo -e "$caffeine\n$scrot\n$calendar\n$notification" | rofi -dmenu -theme ~/.config/rofi/themes/toolmenu_v.rasi )

case "$chosen" in
  "$caffeine") $HOME/.local/bin/caffeine-mode --toggle ;;
  "$scrot")  $HOME/.local/bin/rofi-screenshot-menu;;
  "$calendar") $HOME/.local/bin/show-calendar-days ;;
  "$notification") $HOME/.local/bin/dunst-notifications-toggle --toggle;;
esac


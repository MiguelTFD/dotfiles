#!/bin/bash
set -euo pipefail

# ─── Constants ────────────────────────────────────────────────────────────────
readonly PALETTE_DIR="$HOME/.local/share/palette"
readonly CURRENT_DIR="$PALETTE_DIR/current"
readonly STATE_FILE="$HOME/.local/state/theme-manager/theme-mode.txt"
readonly LOCK_FILE="/tmp/theme-manager.lock"
readonly DEFAULT_THEME="dark"
readonly DUNST_SETTLE_DELAY=0.3

declare -rA SYSTEM_CONFIGS=(
  ["gtk3.palette.ini"]="/etc/gtk-3.0/settings.ini"
  ["lightdm.palette.conf"]="/etc/lightdm/lightdm-gtk-greeter.conf"
  ["cursor.palette.theme"]="/usr/share/icons/default/index.theme"
)

# ─── Logging ──────────────────────────────────────────────────────────────────
log_ok()    { echo "✓ $*"; }
log_warn()  { echo "⚠ $*" >&2; }
log_info()  { echo "→ $*"; }
log_error() { echo "✗ $*" >&2; }

# ─── State ────────────────────────────────────────────────────────────────────
get_theme() { cat "$STATE_FILE"; }

set_theme() {
  local tmp
  tmp=$(mktemp "${STATE_FILE}.XXXXXX")
  echo "$1" > "$tmp" && mv -f "$tmp" "$STATE_FILE" || { rm -f "$tmp"; return 1; }
}

# ─── Init ─────────────────────────────────────────────────────────────────────
init() {
  mkdir -p "$(dirname "$STATE_FILE")" "$CURRENT_DIR" \
    || { log_error "Failed to create required directories"; exit 1; }
  [[ -f "$STATE_FILE" ]] || set_theme "$DEFAULT_THEME"
}

# ─── Core ─────────────────────────────────────────────────────────────────────
sync_user_files() {
  local theme_dir="$1"
  log_info "Syncing user files from: $theme_dir"

  shopt -s nullglob
  local files=("$theme_dir"/*)
  shopt -u nullglob

  if (( ${#files[@]} == 0 )); then
    log_warn "No user files found in: $theme_dir"
    return
  fi

  local file name
  for file in "${files[@]}"; do
    name="${file##*/}"
    cp -f "$file" "$CURRENT_DIR/$name" && log_ok "Updated: $name"
  done
}

sync_system_files() {
  local theme_dir="$1"
  log_info "Syncing system files from: $theme_dir"

  local filename src dst
  for filename in "${!SYSTEM_CONFIGS[@]}"; do
    src="$theme_dir/$filename"
    dst="${SYSTEM_CONFIGS[$filename]}"

    if [[ ! -f "$src" ]]; then
      log_warn "Skipping missing file: $src"
      continue
    fi

    sudo install -D "$src" "$dst" && log_ok "System: $dst"
  done
}

notify_change() {
  local theme="$1"
  command -v dunstify &>/dev/null || return 0
  dunstify -u low -t 2000 "Theme: ${theme^}" "Colors updated"
}

reload_apps() {
  local theme="$1"
  log_info "Reloading apps..."

  systemctl --user restart dunst.service &>/dev/null && log_ok "dunst restarted"

  notify_change "$theme"
  sleep "$DUNST_SETTLE_DELAY"

  i3-msg restart &>/dev/null || true
}

# ─── Actions ──────────────────────────────────────────────────────────────────
cleanup_lock() {
  exec 9>&-
  rm -f "$LOCK_FILE"
}

apply_theme() {
  local theme="$1"
  local theme_dir="$PALETTE_DIR/$theme"

  log_info "Applying theme: ${theme^}"
  [[ -d "$theme_dir" ]] || { log_error "Theme directory not found: $theme_dir"; exit 1; }

  sync_user_files   "$theme_dir"
  sync_system_files "$theme_dir"
}

load_theme() {
  local theme="$1"
  apply_theme "$theme"
  reload_apps "$theme"
}

toggle_theme() {
  exec 9>"$LOCK_FILE"
  flock -n 9 || { log_error "Theme change already in progress."; exit 1; }
  trap cleanup_lock EXIT

  local current new
  current=$(get_theme)
  if [[ "$current" == "dark" ]]; then new="light"; else new="dark"; fi

  log_info "Switching: ${current^} → ${new^}"

  apply_theme "$new"
  set_theme   "$new"
  reload_apps "$new"
}

# ─── Entry point ──────────────────────────────────────────────────────────────
usage() {
  echo "Usage: $(basename "$0") {--toggle|--load}" >&2
  echo "  --toggle   Switch between dark and light themes" >&2
  echo "  --load     Reload the current theme" >&2
  exit 1
}

init

case "${1:-}" in
  --toggle) toggle_theme ;;
  --load)   load_theme "$(get_theme)" ;;
  *)        usage ;;
esac

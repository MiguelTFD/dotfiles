# Exclude everything by default
/*

# ── Root dotfiles ─────────────────────────────────────────────
!/.bashrc
!/.bash_aliases
!/.bash_profile
!/.profile
!/.gitconfig
!/.gitignore
!/.openv

# ── .config ───────────────────────────────────────────────────
!/.config
/.config/*
!/.config/alacritty
!/.config/bat
!/.config/btop/
/.config/btop/*
!/.config/btop/btop.conf
!/.config/dunst
!/.config/feh
!/.config/gtk-3.0/
/.config/gtk-3.0/*
!/.config/gtk-3.0/settings.ini
!/.config/i3
!/.config/lf
!/.config/neofetch
!/.config/picom
!/.config/polybar
!/.config/rofi
!/.config/starship.toml

# ── Themes, fonts & icons ─────────────────────────────────────
!/.themes
!/.fonts
!/.icons

# ── .local/bin ────────────────────────────────────────────────
!/.local
/.local/*
!/.local/bin

# ── .local/share ──────────────────────────────────────────────
!/.local/share
/.local/share/*
!/.local/share/wallpapers
!/.local/share/palette
/.local/share/palette/*
!/.local/share/palette/dark
!/.local/share/palette/light

# ── .local/state ──────────────────────────────────────────────
!/.local/state
/.local/state/*
!/.local/state/theme-manager
/.local/state/theme-manager/*
!/.local/state/theme-manager/.gitkeep

# ── Vim ───────────────────────────────────────────────────────
!/.vim
/.vim/*
!/.vim/vimrc
!/.vim/snippets
!/.vim/scripts
!/.vim/undodir
/.vim/undodir/*
!/.vim/undodir/.gitkeep
!/.vim/logs
/.vim/logs/*
!/.vim/logs/.gitkeep
